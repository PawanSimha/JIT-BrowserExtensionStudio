{
  "manifest_version": 3,
  "name": "Smart Refresh & Page Monitor",
  "version": "1.0.0",
  "description": "Auto-refresh pages with smart intervals and monitor content for keywords.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/Refreshner.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/Refreshner.png",
    "48": "icons/Refreshner.png",
    "128": "icons/Refreshner.png"
  }
}
