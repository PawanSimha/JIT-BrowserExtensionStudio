{
  "manifest_version": 3,
  "name": "MutedHue",
  "version": "1.0.0",
  "description": "Replaces bright blue text selection with a subtle,\nadaptive grey highlight on every website.",
  "icons": {
    "16": "icons/MutedHue.png",
    "32": "icons/MutedHue.png",
    "48": "icons/MutedHue.png",
    "128": "icons/MutedHue.png"
  },
  "action": {
    "default_icon": "icons/MutedHue.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
