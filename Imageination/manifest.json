{
  "manifest_version": 3,
  "name": "Imageination",
  "version": "2.0.0",
  "description": "Download images, videos and audio from any webpage: PNG, JPEG, WebP, SVG, GIF, AVIF, ICO, MP4, WebM, MP3 and more.",
  "permissions": ["activeTab", "downloads", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
